<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#0F172A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="#E2E8F0"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Run this on the phone. Scan the LAN, select a camera, then open the HLS URL from another device on the same Wi‑Fi."
            android:textColor="#94A3B8"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/rtspInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="rtsp://camera-ip:554/path"
            android:inputType="textUri"
            android:textColor="#E2E8F0"
            android:textColorHint="#64748B"
            android:backgroundTint="#38BDF8" />

        <EditText
            android:id="@+id/usernameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="username (optional)"
            android:inputType="textEmailAddress"
            android:textColor="#E2E8F0"
            android:textColorHint="#64748B"
            android:backgroundTint="#38BDF8" />

        <EditText
            android:id="@+id/passwordInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="password (optional)"
            android:inputType="textPassword"
            android:textColor="#E2E8F0"
            android:textColorHint="#64748B"
            android:backgroundTint="#38BDF8" />

        <EditText
            android:id="@+id/baseusTargetsInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Baseus capture IPs, e.g. 192.168.4.25"
            android:inputType="textUri"
            android:textColor="#E2E8F0"
            android:textColorHint="#64748B"
            android:backgroundTint="#38BDF8" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Baseus app traffic capture"
            android:textColor="#CBD5E1"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/proxyStatusValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E2E8F0"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/proxyStartButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Start proxy capture" />

            <Button
                android:id="@+id/proxyStopButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Stop proxy" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Baseus VPN capture"
            android:textColor="#CBD5E1"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/vpnStatusValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E2E8F0"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/vpnStartButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Start VPN capture" />

            <Button
                android:id="@+id/vpnStopButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Stop VPN" />
        </LinearLayout>

        <EditText
            android:id="@+id/vicohomeEmailInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Baseus / Vicohome email"
            android:inputType="textEmailAddress"
            android:textColor="#E2E8F0"
            android:textColorHint="#64748B"
            android:backgroundTint="#38BDF8" />

        <EditText
            android:id="@+id/vicohomePasswordInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Baseus / Vicohome password"
            android:inputType="textPassword"
            android:textColor="#E2E8F0"
            android:textColorHint="#64748B"
            android:backgroundTint="#38BDF8" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Cloud region"
            android:textColor="#CBD5E1"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/vicohomeRegionSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:backgroundTint="#38BDF8" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/scanButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Scan cameras" />

            <Button
                android:id="@+id/startButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="Start bridge" />

            <Button
                android:id="@+id/captureButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Capture Baseus" />

            <Button
                android:id="@+id/vicohomeButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Baseus cloud sync" />

            <Button
                android:id="@+id/stopButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="Stop" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Scan status"
            android:textColor="#CBD5E1"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/scanStatusValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E2E8F0"
            android:textSize="14sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Discovered cameras"
            android:textColor="#CBD5E1"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/cameraContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Baseus cloud devices / clips"
            android:textColor="#CBD5E1"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/vicohomeContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Status"
            android:textColor="#CBD5E1"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/statusValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E2E8F0"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Server"
            android:textColor="#CBD5E1"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/serverValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E2E8F0"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="HLS"
            android:textColor="#CBD5E1"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/hlsValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E2E8F0"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Bridge ID"
            android:textColor="#CBD5E1"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/bridgeIdValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#E2E8F0"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Logs"
            android:textColor="#CBD5E1"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/logValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="#CBD5E1"
            android:textSize="12sp" />

        <Button
            android:id="@+id/exportLogsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Download log file" />
    </LinearLayout>
</ScrollView>
