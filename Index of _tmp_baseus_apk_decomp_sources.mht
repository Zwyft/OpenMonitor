@charset "utf-8";

body { font-family: ui-monospace, Menlo, Monaco, monospace; margin: 16px; background: rgb(11, 16, 32); color: rgb(219, 230, 255); }

a { color: rgb(140, 194, 255); text-decoration: none; }

a:hover { text-decoration: underline; }

ul { list-style: none; padding: 0px; margin: 12px 0px 0px; display: flex; flex-direction: column; gap: 8px; }

.file-row { display: grid; grid-template-columns: minmax(0px, 1fr) auto; align-items: center; gap: 10px; }

.file-link { display: block; padding: 10px 12px; border: 1px solid rgb(40, 64, 95); border-radius: 10px; background: rgb(15, 27, 51); overflow-wrap: anywhere; }

.header-actions { display: flex; align-items: center; gap: 10px; margin-top: 10px; flex-wrap: wrap; }

.header-parent-link { color: rgb(158, 200, 255); font-size: 14px; padding: 8px 10px; border: 1px solid rgb(42, 69, 105); border-radius: 10px; background: rgb(16, 31, 58); }

.header-parent-link:hover { text-decoration: none; filter: brightness(1.08); }

.header-open-btn { height: 42px; padding: 0px 14px; border: 1px solid rgb(79, 141, 224); border-radius: 10px; background: linear-gradient(135deg, rgb(46, 110, 230) 0%, rgb(61, 140, 255) 100%); color: rgb(238, 246, 255); font-weight: 700; letter-spacing: 0.01em; cursor: pointer; box-shadow: rgba(33, 90, 199, 0.35) 0px 6px 18px; }

.header-open-btn:hover { filter: brightness(1.08); }

.header-open-btn:disabled { opacity: 0.6; cursor: default; }

.picker-summary { margin: 10px 0px 0px; color: rgb(184, 213, 255); max-width: 60rem; line-height: 1.45; }

.row-actions { display: inline-flex; align-items: center; gap: 8px; min-width: 42px; justify-content: flex-end; }

.icon-btn { display: inline-flex; align-items: center; justify-content: center; width: 42px; height: 42px; border: 1px solid rgb(54, 85, 122); border-radius: 10px; background: rgb(22, 38, 67); color: rgb(219, 230, 255); text-decoration: none; cursor: pointer; }

.icon-btn:hover { filter: brightness(1.08); text-decoration: none; }

.status { margin: 10px 0px 0px; color: rgb(140, 194, 255); min-height: 1.25em; }

h1 { font-size: 18px; margin: 0px; word-break: break-all; }

@media (max-width: 640px) {
  body { margin: 12px; }
  .file-row { gap: 8px; }
  .file-link { font-size: 15px; padding: 12px; }
  .icon-btn { width: 44px; height: 44px; }
}
